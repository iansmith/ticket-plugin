# Harvester credentials — template (BILL-37).
#
# Copy this file to `.harvester.env` (which is GITIGNORED) and fill in real
# tokens, then `source .harvester.env` before running a harvester:
#
#     cp .harvester.env.example .harvester.env
#     # edit .harvester.env, paste your token(s)
#     source .harvester.env
#     python -m rag_service.harvesters.linear sync-ticket LOU-102
#
# Or set these vars directly in the container / cron environment instead of
# using a file. The harvesters read ONLY from the environment — this file is a
# convenience, not a config the code parses. NEVER commit `.harvester.env`.
#
# These are READ-ONLY credentials: the harvesters only fetch tickets, never
# write to the source. Grant the minimum (read) scope. See
# design/ticket-rag.md § Harvester credentials for the exact click-through
# steps and scopes.

# --- Linear (the BILL-37 harvester) -----------------------------------------
# Personal API key, scope = Read. Workspace-scoped settings URL (the page is
# buried in Linear's UI — swap <workspace> for your slug):
#   https://linear.app/<workspace>/settings/account/security
# Raw key in the Authorization header (NO "Bearer " prefix).
export LINEAR_API_KEY="lin_api_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- JIRA (harvester not built yet; documented for parity) ------------------
# Scoped API token (read:jira-work [+ read:jira-user]) from
#   https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA uses HTTP Basic auth: <email>:<token>.
# export JIRA_EMAIL="you@example.com"
# export JIRA_API_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"
# export JIRA_BASE_URL="https://your-site.atlassian.net"
