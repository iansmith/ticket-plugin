# Harvester credentials — template (BILL-37).
#
# Copy this file to `.harvester.toml` (which is GITIGNORED) and fill in real
# tokens.  The harvesters read this file automatically (TOML format, parsed via
# tomllib) and also accept the same keys as environment variables — env wins:
#
#     cp .harvester.toml.example .harvester.toml
#     # edit .harvester.toml, paste your token(s)
#
# Alternatively set the env vars directly in the container / cron environment
# (e.g. `export LINEAR_API_KEY=lin_api_...`) and skip the file entirely.
# The Makefile `rag-dev-start` target reads .harvester.toml automatically.
#
# These are READ-ONLY credentials: the harvesters only fetch tickets, never
# write to the source. Grant the minimum (read) scope. See
# design/ticket-rag.md § Harvester credentials for the exact click-through
# steps and scopes.
#
# NEVER commit `.harvester.toml`.

# --- Linear (the BILL-37 harvester) -----------------------------------------
# Personal API key, scope = Read. Workspace-scoped settings URL (the page is
# buried in Linear's UI — swap <workspace> for your slug):
#   https://linear.app/<workspace>/settings/account/security
# Raw key in the Authorization header (NO "Bearer " prefix).
[linear]
api_key = "lin_api_xxxxxxxxxxxxxxxxxxxxxxxx"

# --- JIRA (harvester not built yet; documented for parity) ------------------
# Scoped API token (read:jira-work [+ read:jira-user]) from
#   https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA uses HTTP Basic auth: <email>:<token>.
# [jira]
# email     = "you@example.com"
# api_token = "xxxxxxxxxxxxxxxxxxxxxxxx"
# base_url  = "https://your-site.atlassian.net"
